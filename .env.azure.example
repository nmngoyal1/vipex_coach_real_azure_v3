# Set this to AZURE to use real Azure adapters instead of local simulators.
RUNTIME_MODE=AZURE

# Teams / Bot Framework
BOT_APP_ID=
BOT_APP_PASSWORD=
BOT_TENANT_ID=
PUBLIC_BASE_URL=https://<container-app-fqdn>

# Azure Service Bus
SERVICE_BUS_FULLY_QUALIFIED_NAMESPACE=<namespace>.servicebus.windows.net
SERVICE_BUS_CONNECTION_STRING=
SERVICE_BUS_QUEUE_NAME=vipex-jobs

# Azure Cosmos DB
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_KEY=
COSMOS_DATABASE=vipex
COSMOS_JOBS_CONTAINER=jobs
COSMOS_SESSIONS_CONTAINER=sessions
COSMOS_RULES_CONTAINER=marketRules
COSMOS_FEEDBACK_CONTAINER=feedback

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<service>.search.windows.net
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=vipex-kb

# Azure AI Foundry / Azure OpenAI deployment
AZURE_OPENAI_ENDPOINT=https://<azure-openai>.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.2
AZURE_OPENAI_API_VERSION=2024-10-21

# Fabric / OneLake
FABRIC_WORKSPACE_ID=
ONELAKE_MATERIAL_PATH=

# Observability
APPLICATIONINSIGHTS_CONNECTION_STRING=
ONELAKE_ACCOUNT_URL=https://onelake.dfs.fabric.microsoft.com
ONELAKE_FILE_SYSTEM=<fabric-workspace-or-lakehouse-filesystem>
ONELAKE_MATERIAL_PATH=<lakehouse>/Files/material_master.csv

# Azure Cache for Redis - used for idempotency, rate limits, and hot session reads
REDIS_URL=rediss://<redis-hostname>:6380
REDIS_PASSWORD=<redis-access-key>

# Azure AI Document Intelligence - used for screenshots, handwritten notes, whiteboard/PDF OCR
DOCUMENT_INTELLIGENCE_ENDPOINT=https://<doc-intelligence-name>.cognitiveservices.azure.com/
DOCUMENT_INTELLIGENCE_KEY=<doc-intelligence-key>
